# Example environment variables for connecting to Neon Postgres
# You can also provide a single DATABASE_URL instead of the individual parts.

# Option A: Full DATABASE_URL (preferred)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Option B: Individual parts
NEON_HOST=your-neon-host
NEON_PORT=5432
NEON_DB=your_database
NEON_USER=your_user
NEON_PASSWORD=your_password
NEON_SSLMODE=require
